  { "rule": "DOMAIN-SUFFIX,gql.twitch.tv,Обход качества Twitch" },

  { "comment": "=== ОСТАЛЬНОЙ ТРАФИК TWITCH (ВИДЕО, ЧАТ) — НАПРЯМУЮ ===" },
  { "rule": "DOMAIN-SUFFIX,twitch.tv,DIRECT" },
  { "rule": "DOMAIN-SUFFIX,ttvnw.net,DIRECT" },
  { "rule": "DOMAIN-SUFFIX,jtvnw.net,DIRECT" },

  { "comment": "=== ОСТАЛЬНЫЕ СЕРВИСЫ ===" },
  { "rule": "RULE-SET,youtube,YouTube" },
  { "rule": "RULE-SET,discord,Discord" },
  { "rule": "RULE-SET,ai,AI" },

  { "rule": "RULE-SET,meta,Meta,no-resolve" },

  { "rule": "RULE-SET,twitter,Геоблок" },
  { "rule": "RULE-SET,tiktok,Геоблок" },
  { "rule": "RULE-SET,netflix,Геоблок" },

  { "rule": "RULE-SET,porno,Геоблок" },
  { "rule": "RULE-SET,torrent,Torrent" },
  { "rule": "RULE-SET,tools,Геоблок" },
  { "rule": "RULE-SET,socials,Геоблок" },
  { "rule": "RULE-SET,music,Геоблок" },
  { "rule": "RULE-SET,games,Геоблок" },
  
  { "rule": "RULE-SET,Ubisoft,Игры" },
  { "rule": "RULE-SET,EA,Игры" },
  { "rule": "RULE-SET,Blizzard,Игры" },
  { "rule": "RULE-SET,Epic,Игры" },

  { "rule": "DOMAIN-KEYWORD,notion,Геоблок" },
  { "rule": "DOMAIN-SUFFIX,ntc.party,PROXY" },

  { "comment": "=== СЛУЖЕБНЫЙ ТРАФИК GOOGLE И CHROME ===" },
  { "rule": "DOMAIN-SUFFIX,googleapis.com,DIRECT" },
  { "rule": "DOMAIN-SUFFIX,gstatic.com,DIRECT" },
  { "rule": "DOMAIN-SUFFIX,google.com,DIRECT" },
  { "rule": "DOMAIN-KEYWORD,chrome,DIRECT" },

  { "comment": "Вручную направляем Activision и матчмейкинг через нужный прокси" },
