[
  { "rule": "RULE-SET,private-ips,DIRECT,no-resolve" },
  { "rule": "RULE-SET,private-domains,DIRECT" },
  { "comment": "=== РУССКИЕ САЙТЫ И ПРИЛОЖЕНИЯ ===" },
  { "rule": "RULE-SET,ru-apps,DIRECT", "devices": ["mobile"] },
  { "rule": "RULE-SET,category-ru,DIRECT" },
  { "rule": "RULE-SET,whitelist,DIRECT" },
  { "rule": "RULE-SET,direct-ips,DIRECT,no-resolve" },

  { "comment": "=== TELEGRAM ===" },
  { "rule": "RULE-SET,telegram,Telegram" },

  { "comment": "=== БЛОКИРОВКА БЕСПОЛЕЗНОЙ РЕКЛАМЫ TWITCH (ТО, ЧТО ЕЩЁ МОЖНО ЗАБЛОКИРОВАТЬ) ===" },
  { "rule": "DOMAIN-SUFFIX,adserver.twitch.tv,REJECT" },
  { "rule": "DOMAIN-SUFFIX,ads.twitch.tv,REJECT" },
  { "rule": "DOMAIN-KEYWORD,twitch-ads,REJECT" },
  { "rule": "DOMAIN-KEYWORD,amazon-adsystem,REJECT" },

