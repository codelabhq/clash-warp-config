  { "rule": "DOMAIN-SUFFIX,callofduty.com,Игры" },
  { "rule": "DOMAIN-SUFFIX,demonware.net,Игры" },
  { "rule": "DOMAIN-SUFFIX,mw3.demonware.net,Игры" },

  { "comment": "Домены для которых жалко создавать RULE-SET" },
